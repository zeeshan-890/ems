{
  "schemaVersion": 2,
  "dockerfileLines": [
    "FROM node:20-alpine AS build",
    "WORKDIR /app",
    "COPY web_frontend/package*.json ./",
    "RUN npm install",
    "COPY web_frontend ./",
    "RUN npm run build",
    "FROM nginx:1.27-alpine",
    "COPY web_frontend/nginx.conf /etc/nginx/conf.d/default.conf",
    "COPY --from=build /app/dist /usr/share/nginx/html",
    "EXPOSE 80"
  ]
}
